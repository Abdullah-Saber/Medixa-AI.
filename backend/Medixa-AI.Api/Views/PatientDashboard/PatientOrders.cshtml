@model IEnumerable<Medixa_AI.Domain.Entities.TestOrder>
@{
    ViewData["Title"] = "Patient Orders";
    var patientId = Context.Request.RouteValues["patientId"]?.ToString() ?? "Unknown";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5>Orders for Patient - @patientId.Substring(0, Math.Min(8, patientId.Length))</h5>
                <div>
                    <a href="@Url.Action("Index", "PatientDashboard")" class="btn btn-secondary">Back to Dashboard</a>
                    <a href="@Url.Action("Orders", "PatientDashboard")" class="btn btn-info">All Orders</a>
                </div>
            </div>
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Order Date</th>
                            <th>Status</th>
                            <th>Test Count</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>@order.OrderID.ToString().Substring(0, 8)</td>
                                <td>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <span class="badge @(order.Status == Medixa_AI.Domain.Enums.OrderStatus.Completed ? "bg-success" : 
                                                   order.Status == Medixa_AI.Domain.Enums.OrderStatus.Pending ? "bg-warning" : "bg-info")">
                                        @order.Status
                                    </span>
                                </td>
                                <td>@(order.OrderDetails?.Count ?? 0)</td>
                                <td>
                                    <a href="@Url.Action("Details", "Order", new { id = order.OrderID })" class="btn btn-sm btn-primary">View Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (!Model.Any())
                {
                    <div class="text-center text-muted">
                        <p>No orders found for this patient.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
