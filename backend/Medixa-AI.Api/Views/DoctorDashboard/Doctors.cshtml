@model IEnumerable<Medixa_AI.Domain.Entities.Doctor>
@{
    ViewData["Title"] = "Doctors";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5>All Doctors</h5>
                <a href="@Url.Action("Index", "DoctorDashboard")" class="btn btn-secondary">Back to Dashboard</a>
            </div>
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Doctor ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Specialization</th>
                            <th>Phone</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doctor in Model)
                        {
                            <tr>
                                <td>@doctor.DoctorID.ToString().Substring(0, 8)</td>
                                <td>@doctor.FullName</td>
                                <td>@doctor.Email</td>
                                <td>@doctor.Specialization</td>
                                <td>@doctor.Phone</td>
                                <td>
                                    @if (doctor.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (!Model.Any())
                {
                    <div class="text-center text-muted">
                        <p>No doctors found.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
