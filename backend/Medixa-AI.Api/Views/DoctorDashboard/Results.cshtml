@model IEnumerable<Medixa_AI.Domain.Entities.TestResult>
@{
    ViewData["Title"] = "Results";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5>All Results</h5>
                <a href="@Url.Action("Index", "DoctorDashboard")" class="btn btn-secondary">Back to Dashboard</a>
            </div>
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Result ID</th>
                            <th>Order ID</th>
                            <th>Patient ID</th>
                            <th>Test Name</th>
                            <th>Result Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var result in Model)
                        {
                            <tr>
                                <td>@result.ResultID.ToString().Substring(0, 8)</td>
                                <td>@result.OrderDetail.OrderID.ToString().Substring(0, 8)</td>
                                <td>@result.OrderDetail.Order.PatientID.ToString().Substring(0, 8)</td>
                                <td>@result.OrderDetail.Test.TestName</td>
                                <td>@result.ResultDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @if (string.IsNullOrEmpty(result.ResultText))
                                    {
                                        <span class="badge bg-warning">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", "Result", new { id = result.ResultID })" class="btn btn-sm btn-primary">View Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if (!Model.Any())
                {
                    <div class="text-center text-muted">
                        <p>No results found.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
